{
  "name": "refuges-gpx-enricher",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "license": "MIT",
  "description": "Web-app desktop qui enrichit un GPX existant avec les refuges, cabanes, gîtes et points d'eau de refuges.info, et exporte une fiche d'étape PDF imprimable.",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write \"src/**/*.{ts,tsx,astro,css,md}\""
  },
  "dependencies": {
    "@astrojs/react": "5.0.5",
    "@radix-ui/react-checkbox": "1.3.3",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-scroll-area": "1.2.10",
    "@radix-ui/react-separator": "1.1.8",
    "@radix-ui/react-slider": "1.3.6",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-tooltip": "1.2.8",
    "@radix-ui/react-visually-hidden": "^1.2.4",
    "@tailwindcss/postcss": "4.2.4",
    "@turf/turf": "7.3.5",
    "astro": "6.3.3",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "1.16.0",
    "maplibre-gl": "5.24.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "tailwind-merge": "3.6.0",
    "tailwindcss": "4.2.4",
    "zod": "4.4.3",
    "zustand": "5.0.13"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@testing-library/react": "16.3.2",
    "@types/node": "25.8.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "prettier": "3.8.3",
    "prettier-plugin-astro": "0.14.1",
    "typescript": "6.0.3",
    "vitest": "4.1.6"
  },
  "overrides": {
    "vite": "^7"
  }
}
