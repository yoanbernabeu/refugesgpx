---
// Landing page statique (Astro), rendue côté serveur pour le SEO.
// Cachée dynamiquement par body.is-app quand un GPX est chargé.
---

<header class="landing-nav rise" style="position: relative; z-index: 10;">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-5">
    <a href="/" class="flex items-baseline gap-2 no-underline">
      <span class="text-2xl leading-none" aria-hidden>🥾</span>
      <span class="font-display text-xl font-semibold text-[var(--color-ink)]">Refuges<span class="text-[var(--color-accent)]">.</span>GPX</span>
    </a>
    <nav class="hidden items-center gap-7 text-sm md:flex">
      <a href="#fonctionnement" class="text-[var(--color-ink-soft)] hover:text-[var(--color-accent)]">Comment ça marche</a>
      <a href="#pour-qui" class="text-[var(--color-ink-soft)] hover:text-[var(--color-accent)]">Pour qui</a>
      <a href="#donnees" class="text-[var(--color-ink-soft)] hover:text-[var(--color-accent)]">Sources</a>
      <a href="https://github.com/yoanbernabeu/refugesgpx" target="_blank" rel="noopener" class="text-[var(--color-ink-soft)] hover:text-[var(--color-accent)]">GitHub ↗</a>
    </nav>
  </div>
</header>

<main class="landing">
  <!-- ╔══════════════════════════════════════════════════════════════
       HERO
       ══════════════════════════════════════════════════════════════ -->
  <section class="relative overflow-hidden">
    <div class="topo-bg"></div>
    <div class="grain"></div>

    <div class="relative mx-auto max-w-6xl px-6 pb-16 pt-12 md:pb-24 md:pt-20">
      <div class="mx-auto max-w-3xl text-center">
        <p class="rise rise-1 section-num">Étape 0 — préparatifs</p>
        <h1 class="rise rise-2 font-display mt-4 text-5xl font-semibold leading-[0.95] tracking-tight text-[var(--color-ink)] md:text-7xl">
          Votre tracé, <span class="crayon italic">enrichi</span> des <span class="text-[var(--color-accent)]">refuges</span> du coin.
        </h1>
        <p class="rise rise-3 mx-auto mt-7 max-w-2xl text-lg leading-relaxed text-[var(--color-ink-soft)] md:text-xl">
          Déposez votre GPX. L'app repère refuges, cabanes, gîtes, points d'eau et ravitaillement
          à proximité du tracé. Vous repartez avec un GPX enrichi et un topo PDF, prêts pour le
          bivouac.
        </p>

        <div class="rise rise-4 mt-9 flex flex-wrap items-center justify-center gap-5">
          <button type="button" data-open-app class="btn-ink">
            Charger mon GPX
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7" /></svg>
          </button>
          <a href="#fonctionnement" class="btn-ghost">Voir comment ça marche</a>
        </div>

        <div class="rise rise-5 mt-8 flex flex-wrap items-center justify-center gap-x-7 gap-y-2 text-sm text-[var(--color-ink-mute)]">
          <span class="flex items-center gap-1.5">
            <span class="inline-block h-1.5 w-1.5 rounded-full bg-[var(--color-moss)]"></span>
            Sans inscription
          </span>
          <span class="flex items-center gap-1.5">
            <span class="inline-block h-1.5 w-1.5 rounded-full bg-[var(--color-moss)]"></span>
            Votre GPX reste dans le navigateur
          </span>
          <span class="flex items-center gap-1.5">
            <span class="inline-block h-1.5 w-1.5 rounded-full bg-[var(--color-moss)]"></span>
            Open-source MIT
          </span>
        </div>
      </div>

      <!-- Pictogramme topo illustratif, sous le hero, centré -->
      <div class="rise rise-3 mx-auto mt-14 w-full max-w-2xl">
        <svg viewBox="0 0 400 260" class="h-auto w-full" role="img" aria-label="Illustration d'un tracé enrichi de POIs">
          <defs>
            <pattern id="dots" x="0" y="0" width="14" height="14" patternUnits="userSpaceOnUse">
              <circle cx="2" cy="2" r="1" fill="var(--color-ink)" opacity="0.14" />
            </pattern>
          </defs>
          <rect width="400" height="260" fill="url(#dots)" />

          <!-- Silhouettes : arrière puis avant. Hauteurs réduites pour laisser la trace clairement visible dans les vallées. -->
          <!-- montagne arrière -->
          <path
            d="M-20 230 L 50 110 L 110 165 L 180 75 L 260 155 L 330 105 L 420 175 L 420 260 L -20 260 Z"
            fill="var(--color-paper-deep)"
            stroke="var(--color-ink)"
            stroke-width="1.2"
          />
          <!-- montagne avant -->
          <path
            d="M-20 250 L 40 195 L 100 220 L 165 175 L 235 215 L 300 180 L 360 215 L 420 195 L 420 260 L -20 260 Z"
            fill="var(--color-paper-warm)"
            stroke="var(--color-ink)"
            stroke-width="1.2"
          />

          <!-- Trace : démarre en vallée gauche, passe dans les cols, termine sans dépasser. -->
          <path
            d="M20 245 Q 60 235 100 225 T 200 210 T 290 205 T 380 220"
            fill="none"
            stroke="var(--color-accent)"
            stroke-width="2.8"
            stroke-linecap="round"
            stroke-dasharray="6 5"
          />

          <!-- Waypoints, posés sur la trace : marker carto avec icône Lucide blanche -->
          <!-- Point d'eau (bleu) -->
          <g transform="translate(80 231)">
            <circle r="11" fill="#2C7DA0" stroke="#1A1A1A" stroke-width="1.8" />
            <g transform="translate(-7 -7) scale(0.6)" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22a7 7 0 0 0 7-7c0-2-1-3.9-3-5.5s-3.5-4-4-6.5c-.5 2.5-2 4.9-4 6.5C6 11.1 5 13 5 15a7 7 0 0 0 7 7z"/>
            </g>
          </g>
          <!-- Cabane (vert mousse) -->
          <g transform="translate(180 213)">
            <circle r="11" fill="#5E6F4A" stroke="#1A1A1A" stroke-width="1.8" />
            <g transform="translate(-7 -7) scale(0.6)" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3.5 21 14 3"/><path d="M20.5 21 14 3"/><path d="M3.5 21h17"/><path d="M12 12v9"/>
            </g>
          </g>
          <!-- Refuge gardé (rouge accent) -->
          <g transform="translate(290 205)">
            <circle r="12" fill="#B85C38" stroke="#1A1A1A" stroke-width="1.8" />
            <g transform="translate(-7.5 -7.5) scale(0.62)" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>
            </g>
          </g>

          <!-- Annotation manuscrite, centrée en haut -->
          <text
            x="200"
            y="36"
            text-anchor="middle"
            font-family="var(--font-display)"
            font-style="italic"
            font-size="13"
            fill="var(--color-ink-mute)"
          >— Tracé + POIs sélectionnés</text>
        </svg>
      </div>
    </div>
  </section>

  <!-- ╔══════════════════════════════════════════════════════════════
       FONCTIONNEMENT — 3 étapes
       ══════════════════════════════════════════════════════════════ -->
  <section id="fonctionnement" class="border-t border-[var(--color-paper-deep)] bg-[var(--color-paper-warm)]">
    <div class="mx-auto max-w-6xl px-6 py-20 md:py-28">
      <p class="section-num">Comment ça marche</p>
      <h2 class="font-display mt-3 text-4xl font-semibold leading-tight text-[var(--color-ink)] md:text-5xl">
        Du GPX au topo, en trois temps.
      </h2>

      <div class="mt-14 grid gap-10 md:grid-cols-3 md:gap-8">
        <article class="relative">
          <div class="font-display text-7xl font-semibold leading-none text-[var(--color-accent)]">01</div>
          <h3 class="font-display mt-4 text-2xl font-semibold text-[var(--color-ink)]">Déposez le GPX</h3>
          <p class="mt-3 text-[var(--color-ink-soft)]">
            Le tracé que vous avez préparé sur <strong>OpenRunner, Komoot, Visorando, Strava</strong>
            ou n'importe quel outil. Le fichier reste dans votre navigateur, jamais sur un serveur.
          </p>
        </article>

        <article class="relative">
          <div class="font-display text-7xl font-semibold leading-none text-[var(--color-accent)]">02</div>
          <h3 class="font-display mt-4 text-2xl font-semibold text-[var(--color-ink)]">Ajustez la distance</h3>
          <p class="mt-3 text-[var(--color-ink-soft)]">
            Un curseur entre <span class="font-mono text-sm">100 m</span> et
            <span class="font-mono text-sm">5 km</span>. L'app affiche refuges gardés, cabanes,
            gîtes, points d'eau et passages délicats dans le rayon choisi, avec distance au tracé,
            altitude, places disponibles et commentaires récents. <strong>Bivouacs</strong> et
            <strong>ravitaillement en village</strong> activables en option.
          </p>
        </article>

        <article class="relative">
          <div class="font-display text-7xl font-semibold leading-none text-[var(--color-accent)]">03</div>
          <h3 class="font-display mt-4 text-2xl font-semibold text-[var(--color-ink)]">Exportez</h3>
          <p class="mt-3 text-[var(--color-ink-soft)]">
            Cochez les points utiles, téléchargez un <strong>GPX enrichi</strong> à recharger dans
            Komoot, OsmAnd, Gaia ou votre GPS, et générez un <strong>topo PDF</strong>
            imprimable pour le consulter sans réseau en montagne.
          </p>
        </article>
      </div>
    </div>
  </section>

  <!-- ╔══════════════════════════════════════════════════════════════
       POUR QUI
       ══════════════════════════════════════════════════════════════ -->
  <section id="pour-qui" class="relative overflow-hidden border-t border-[var(--color-paper-deep)]">
    <div class="mx-auto grid max-w-6xl gap-12 px-6 py-20 md:grid-cols-[1fr,1.2fr] md:py-28">
      <div>
        <p class="section-num">Public visé</p>
        <h2 class="font-display mt-3 text-4xl font-semibold leading-tight text-[var(--color-ink)] md:text-5xl">
          Pour les randonneuses et randonneurs <span class="italic text-[var(--color-accent)]">autonomes</span>.
        </h2>
        <p class="mt-6 text-lg leading-relaxed text-[var(--color-ink-soft)]">
          Traversées multi-jours, bivouac, GR et GRP, cabanes non gardées, refuges d'hiver, points
          d'eau en alpage : ce que les planificateurs grand public ne savent pas afficher.
        </p>
      </div>

      <ul class="space-y-5">
        <li class="border-l-2 pl-5" style="border-color: #B85C38">
          <div class="font-display text-xl font-semibold text-[var(--color-ink)]">Refuges gardés et gîtes d'étape</div>
          <p class="mt-1 text-[var(--color-ink-soft)]">Réservations, capacité, période d'ouverture, gardien — l'info que vous cherchiez à recouper, avec les derniers commentaires de la communauté.</p>
        </li>
        <li class="border-l-2 pl-5" style="border-color: #5E6F4A">
          <div class="font-display text-xl font-semibold text-[var(--color-ink)]">Cabanes non gardées</div>
          <p class="mt-1 text-[var(--color-ink-soft)]">Couchage de secours, état du toit, poêle, eau à proximité — par celles et ceux qui y sont passés ce mois-ci.</p>
        </li>
        <li class="border-l-2 pl-5" style="border-color: #8B6F47">
          <div class="font-display text-xl font-semibold text-[var(--color-ink)]">Emplacements de bivouac</div>
          <p class="mt-1 text-[var(--color-ink-soft)]">Spots documentés par la communauté Camptocamp — altitude, exposition, accès à l'eau — pour les traversées hors refuges.</p>
        </li>
        <li class="border-l-2 pl-5" style="border-color: #2C7DA0">
          <div class="font-display text-xl font-semibold text-[var(--color-ink)]">Points d'eau</div>
          <p class="mt-1 text-[var(--color-ink-soft)]">Sources, fontaines, robinets, puits, captages — ceux qui décident où s'arrêter en plein été, complétés par OpenStreetMap loin des refuges.</p>
        </li>
        <li class="border-l-2 pl-5" style="border-color: #0F766E">
          <div class="font-display text-xl font-semibold text-[var(--color-ink)]">Ravitaillement en village</div>
          <p class="mt-1 text-[var(--color-ink-soft)]">Supermarchés, épiceries, boulangeries, boucheries, marchés — pour repérer où refaire le sac sur une traversée multi-jours.</p>
        </li>
        <li class="border-l-2 pl-5" style="border-color: #DDA853">
          <div class="font-display text-xl font-semibold text-[var(--color-ink)]">Passages délicats</div>
          <p class="mt-1 text-[var(--color-ink-soft)]">Pas d'escalade, vires, traversées exposées — repérés en amont pour préparer le matériel et le timing.</p>
        </li>
      </ul>
    </div>
  </section>

  <!-- ╔══════════════════════════════════════════════════════════════
       CTA secondaire / commencer
       ══════════════════════════════════════════════════════════════ -->
  <section id="commencer" class="relative bg-[var(--color-ink)] text-[var(--color-paper)]">
    <div class="topo-bg" style="opacity: 0.25;"></div>
    <div class="relative mx-auto max-w-4xl px-6 py-20 text-center md:py-28">
      <p class="section-num text-[var(--color-trail)]">Maintenant</p>
      <h2 class="font-display mt-3 text-4xl font-semibold leading-tight md:text-5xl">
        Glissez votre <span class="text-[var(--color-trail)]">premier GPX</span>.
      </h2>
      <p class="mx-auto mt-5 max-w-2xl text-lg text-[var(--color-paper-warm)]/80">
        Tout se passe ici, dans votre navigateur. Aucun fichier n'est envoyé.
      </p>
      <div class="mt-10">
        <button
          type="button"
          data-open-app
          class="inline-flex items-center gap-3 rounded-full border border-[var(--color-trail)] bg-[var(--color-trail)] px-7 py-4 font-semibold text-[var(--color-ink)] transition hover:translate-y-[-2px] hover:bg-[var(--color-paper)] hover:shadow-lg"
        >
          Ouvrir l'app
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7" /></svg>
        </button>
      </div>
    </div>
  </section>

  <!-- ╔══════════════════════════════════════════════════════════════
       DONNÉES & SOURCES
       ══════════════════════════════════════════════════════════════ -->
  <section id="donnees" class="border-t border-[var(--color-paper-deep)] bg-[var(--color-paper-warm)]">
    <div class="mx-auto max-w-6xl px-6 py-16 md:py-20">
      <p class="section-num">Données & crédits</p>
      <h2 class="font-display mt-3 text-3xl font-semibold leading-tight text-[var(--color-ink)] md:text-4xl">
        Tout part du travail bénévole de la communauté.
      </h2>

      <div class="mt-10 space-y-10">
        <div>
          <p class="text-[10px] font-semibold uppercase tracking-wider text-[var(--color-ink-mute)]">Source principale</p>
          <div class="mt-3 grid gap-8 md:grid-cols-2">
            <div>
              <div class="font-display text-xl font-semibold text-[var(--color-ink)]">refuges.info</div>
              <p class="mt-2 text-[var(--color-ink-soft)]">
                Inventaire collaboratif de plus de 10 000 refuges, cabanes, gîtes et points d'eau
                — le cœur de l'app, activé par défaut.
                <br /><span class="text-sm text-[var(--color-ink-mute)]">CC BY-SA 2.0</span>
              </p>
            </div>
            <div>
              <div class="font-display text-xl font-semibold text-[var(--color-ink)]">OpenStreetMap — fond de carte</div>
              <p class="mt-2 text-[var(--color-ink-soft)]">
                Le fond sous nos pieds, contribué par des milliers de cartographes.
                <br /><span class="text-sm text-[var(--color-ink-mute)]">ODbL</span>
              </p>
            </div>
          </div>
        </div>

        <div>
          <p class="text-[10px] font-semibold uppercase tracking-wider text-[var(--color-ink-mute)]">Sources annexes — opt-in dans l'app</p>
          <div class="mt-3 grid gap-8 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5">
            <div>
              <div class="font-display text-xl font-semibold text-[var(--color-ink)]">OpenStreetMap — points d'eau</div>
              <p class="mt-2 text-[var(--color-ink-soft)]">
                Sources, fontaines, abreuvoirs et bornes d'eau potable interrogés en temps réel
                via <a href="https://overpass-api.de" target="_blank" rel="noopener" class="underline decoration-[var(--color-accent)] underline-offset-2 hover:text-[var(--color-accent)]">Overpass API</a>,
                pour compléter le maillage hydrique loin des refuges.
                <br /><span class="text-sm text-[var(--color-ink-mute)]">ODbL · à vérifier sur le terrain</span>
              </p>
            </div>
            <div>
              <div class="font-display text-xl font-semibold text-[var(--color-ink)]">OpenStreetMap — ravitaillement</div>
              <p class="mt-2 text-[var(--color-ink-soft)]">
                Supermarchés, épiceries, boulangeries, boucheries et marchés en village,
                pour repérer les points de ravito sur les traversées multi-jours.
                <br /><span class="text-sm text-[var(--color-ink-mute)]">ODbL · horaires à recouper</span>
              </p>
            </div>
            <div>
              <div class="font-display text-xl font-semibold text-[var(--color-ink)]">Camptocamp — bivouacs</div>
              <p class="mt-2 text-[var(--color-ink-soft)]">
                Emplacements de bivouac documentés par la communauté
                <a href="https://www.camptocamp.org" target="_blank" rel="noopener" class="underline decoration-[var(--color-accent)] underline-offset-2 hover:text-[var(--color-accent)]">camptocamp.org</a> —
                pratique pour les traversées hors refuges.
                <br /><span class="text-sm text-[var(--color-ink-mute)]">CC BY-SA 3.0 / 4.0</span>
              </p>
            </div>
            <div>
              <div class="font-display text-xl font-semibold text-[var(--color-ink)]">SNCF — gares de voyageurs</div>
              <p class="mt-2 text-[var(--color-ink-soft)]">
                Les 2&nbsp;782 gares voyageurs françaises, depuis l'export officiel
                <a href="https://www.data.gouv.fr/datasets/gares-de-voyageurs-1" target="_blank" rel="noopener" class="underline decoration-[var(--color-accent)] underline-offset-2 hover:text-[var(--color-accent)]">data.gouv.fr</a>,
                pour préparer le départ et le retour en train.
                <br /><span class="text-sm text-[var(--color-ink-mute)]">Licence Ouverte v2 / Etalab</span>
              </p>
            </div>
            <div>
              <div class="font-display text-xl font-semibold text-[var(--color-ink)]">DATAtourisme — hébergements</div>
              <p class="mt-2 text-[var(--color-ink-soft)]">
                Gîtes d'étape, chambres d'hôtes, campings, hôtels et auberges agrégés par
                <a href="https://www.datatourisme.fr" target="_blank" rel="noopener" class="underline decoration-[var(--color-accent)] underline-offset-2 hover:text-[var(--color-accent)]">DATAtourisme</a>
                (réseau ADN Tourisme), pour trouver un repli à toute étape — y compris en cas de météo qui tourne.
                <br /><span class="text-sm text-[var(--color-ink-mute)]">Licence Ouverte / Etalab · ouvertures à recouper</span>
              </p>
            </div>
          </div>
        </div>

        <div class="border-t border-[var(--color-paper-deep)] pt-8">
          <div class="font-display text-xl font-semibold text-[var(--color-ink)]">Vous</div>
          <p class="mt-2 text-[var(--color-ink-soft)]">
            Le code est <a href="https://github.com/yoanbernabeu/refugesgpx" target="_blank" rel="noopener" class="underline decoration-[var(--color-accent)] underline-offset-2 hover:text-[var(--color-accent)]">open-source MIT</a>. Bug, idée, contribution : ouvrez une issue.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ╔══════════════════════════════════════════════════════════════
       FOOTER
       ══════════════════════════════════════════════════════════════ -->
  <footer class="border-t border-[var(--color-paper-deep)] bg-[var(--color-paper)]">
    <div class="mx-auto flex max-w-6xl flex-col items-start justify-between gap-3 px-6 py-8 text-sm text-[var(--color-ink-mute)] md:flex-row md:items-center">
      <p>
        Données © <a href="https://www.refuges.info" target="_blank" rel="noopener" class="underline">refuges.info</a> (CC BY-SA 2.0)
        · <a href="https://www.openstreetmap.org/copyright" target="_blank" rel="noopener" class="underline">OpenStreetMap</a> (ODbL — fond + Overpass)
        · <a href="https://www.camptocamp.org" target="_blank" rel="noopener" class="underline">Camptocamp</a> (CC BY-SA)
        · <a href="https://www.data.gouv.fr/datasets/gares-de-voyageurs-1" target="_blank" rel="noopener" class="underline">SNCF gares</a> (LOV2)
        · <a href="https://www.datatourisme.fr" target="_blank" rel="noopener" class="underline">DATAtourisme</a> (Licence Ouverte) · Code MIT
      </p>
      <p>
        Une création de <a href="https://yoandev.co" target="_blank" rel="noopener" class="underline">yoandev.co</a>
      </p>
    </div>
  </footer>
</main>

<script>
  // Tout bouton avec data-open-app bascule simplement sur l'app.
  // L'utilisateur découvre la carte + la zone de drop dans le panneau.
  const triggerApp = () => {
    document.body.classList.add('is-app');
  };
  document.querySelectorAll('[data-open-app]').forEach((el) => {
    el.addEventListener('click', triggerApp);
  });
</script>
